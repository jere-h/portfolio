---
import { profile } from "../config";
import Icon from "./Icon.astro";

// Build-time split of the name into per-word / per-char spans for the
// masked rise reveal. aria-label on the h1 keeps the accessible name
// intact; the spans are presentation only.
const nameWords = profile.name.split(" ").map((word) => word.split(""));
let charIndex = 0;
---

<!-- On phones the hero is a full-bleed statement: min-height with the
     content centered so the living light is the first impression. On
     larger screens it stays the compact editorial band. -->
<section
  class="relative isolate flex min-h-[40svh] flex-col justify-center overflow-hidden px-5 py-8 sm:min-h-0 sm:justify-start sm:pt-10 sm:pb-8"
  aria-labelledby="hero-name"
>
  <!-- warm orb: permanent no-JS / reduced-motion / no-WebGL fallback -->
  <div class="hero-orb" aria-hidden="true"></div>

  <!-- living light: pointer-reactive WebGL gradient in the same four-stop
       ramp as the orb. Fades in over the orb once the first frame renders;
       stays invisible otherwise (see src/scripts/hero-gradient.ts). -->
  <canvas class="hero-canvas" aria-hidden="true"></canvas>

  <div class="hero-content mx-auto flex max-w-4xl flex-col items-start gap-5 sm:flex-row sm:items-center sm:gap-8">
    <img
      src={profile.avatarUrl}
      alt={`${profile.name}`}
      width="96"
      height="96"
      loading="eager"
      decoding="async"
      class="h-20 w-20 shrink-0 rounded-pill border border-border bg-surface object-cover shadow-md sm:h-24 sm:w-24"
      data-reveal
    />

    <div class="min-w-0" data-reveal data-reveal-delay="1">
      <p class="eyebrow flex items-center gap-1.5">
        <Icon name="pin" size={14} />
        {profile.location}
      </p>

      <h1
        id="hero-name"
        aria-label={profile.name}
        class="hero-name mt-2 font-display font-semibold text-[clamp(3rem,11vw,4.25rem)] sm:text-[clamp(2.5rem,6vw,4.25rem)]"
      >
        {nameWords.map((chars, w) => (
          <>
            <span class="word" aria-hidden="true">
              {chars.map((ch) => (
                <span class="char" style={`--ci: ${charIndex++}`}>{ch}</span>
              ))}
            </span>
            {w < nameWords.length - 1 && " "}
          </>
        ))}
      </h1>

      <p class="mt-1.5 text-base font-medium text-accent sm:text-lg">
        {profile.tagline}
      </p>

      <p class="mt-3 max-w-xl text-[0.95rem] leading-relaxed text-muted sm:text-base">
        {profile.bio}
      </p>

      <div class="mt-5 flex flex-wrap gap-3">
        <a
          href={profile.socials.github}
          target="_blank"
          rel="noopener noreferrer"
          data-magnetic
          class="inline-flex min-h-11 items-center gap-2 rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium text-fg shadow-sm transition-colors duration-200 hover:bg-sand"
        >
          <Icon name="github" size={18} />
          GitHub
        </a>
        <a
          href={`mailto:${profile.email}`}
          data-magnetic
          class="inline-flex min-h-11 items-center gap-2 rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium text-fg shadow-sm transition-colors duration-200 hover:bg-sand"
        >
          <Icon name="mail" size={18} />
          Email
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-orb {
    position: absolute;
    z-index: -1;
    top: -55%;
    right: -8%;
    width: min(40rem, 85vw);
    height: min(40rem, 85vw);
    pointer-events: none;
    border-radius: 999px;
    filter: blur(80px);
    opacity: 0.5;
    background: radial-gradient(
      circle at 50% 42%,
      #ffd9a8 0%,
      #f7849b 34%,
      #e8557f 62%,
      #a93a8f 100%
    );
  }

  :global(:root.dark) .hero-orb {
    opacity: 0.32;
  }

  /* Once the canvas is live it fully covers the hero, so stop
   * compositing the expensive blurred orb underneath it. */
  .hero-orb:has(+ .hero-canvas.is-live) {
    opacity: 0;
    transition: opacity 900ms ease;
  }

  .hero-canvas {
    position: absolute;
    inset: 0;
    /* canvas is a replaced element: inset alone won't stretch it, and
     * without explicit CSS sizing the buffer-size writes in fit() would
     * feed back into layout. */
    width: 100%;
    height: 100%;
    z-index: -1;
    opacity: 0;
    transition: opacity 900ms ease;
    pointer-events: none;
  }

  .hero-canvas.is-live {
    opacity: 1;
  }

  /* Display face details: optical sizing at display scale, plus
   * Fraunces' WONK axis for the editorial personality. */
  .hero-name {
    font-optical-sizing: auto;
    font-variation-settings: "WONK" 1;
    line-height: 1.05;
  }

  /* Masked char rise. Words are the overflow-hidden masks (so the name
   * can wrap on small screens); chars rise inside them with a stagger.
   * The padding/negative-margin pair keeps descenders (y, g) from being
   * clipped by the mask while they move. */
  .word {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
    padding-bottom: 0.14em;
    margin-bottom: -0.14em;
  }

  .char {
    display: inline-block;
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(.js) .char {
      transform: translateY(118%);
      animation: char-rise 640ms var(--ease-tactile) forwards;
      animation-delay: calc(120ms + var(--ci) * 26ms);
    }

    @keyframes char-rise {
      to {
        transform: none;
      }
    }
  }
</style>

<script>
  import { initHeroGradient } from "../scripts/hero-gradient";
  initHeroGradient();
</script>
