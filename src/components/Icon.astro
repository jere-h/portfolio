---
/**
 * Inline SVG icons (no icon font, no external requests). Decorative by
 * default (aria-hidden); pass a `title` to expose an accessible name.
 */
interface Props {
  name:
    | "github"
    | "mail"
    | "star"
    | "fork"
    | "arrow-up-right"
    | "sun"
    | "moon"
    | "pin";
  size?: number;
  title?: string;
  class?: string;
}

const { name, size = 18, title, class: className = "" } = Astro.props;

const paths: Record<Props["name"], string> = {
  github:
    '<path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.4-5.27 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"/>',
  mail:
    '<rect x="2" y="4" width="20" height="16" rx="2.5"/><path d="m3 6.5 9 6 9-6"/>',
  star:
    '<path d="M12 2.5l2.9 6.06 6.6.86-4.85 4.55 1.25 6.53L12 17.9l-5.9 3.06 1.25-6.53L2.5 9.42l6.6-.86L12 2.5Z"/>',
  fork:
    '<circle cx="6" cy="5" r="2.5"/><circle cx="18" cy="5" r="2.5"/><circle cx="12" cy="19" r="2.5"/><path d="M6 7.5v3a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3v-3M12 13.5v3"/>',
  "arrow-up-right": '<path d="M7 17 17 7M8 7h9v9"/>',
  sun:
    '<circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v2.2M12 19.3v2.2M4.6 4.6l1.6 1.6M17.8 17.8l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.6 19.4l1.6-1.6M17.8 6.2l1.6-1.6"/>',
  moon: '<path d="M20 14.2A8 8 0 0 1 9.8 4 8 8 0 1 0 20 14.2Z"/>',
  pin:
    '<path d="M12 21s7-6.06 7-11a7 7 0 1 0-14 0c0 4.94 7 11 7 11Z"/><circle cx="12" cy="10" r="2.6"/>',
};

// Filled marks vs stroked marks.
const filled = name === "github" || name === "star";
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill={filled ? "currentColor" : "none"}
  stroke={filled ? "none" : "currentColor"}
  stroke-width={filled ? undefined : 1.8}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  role={title ? "img" : "presentation"}
  aria-hidden={title ? undefined : "true"}
  aria-label={title}
  set:html={(title ? `<title>${title}</title>` : "") + paths[name]}
/>
