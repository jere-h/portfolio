---
import { profile } from "../config";
import Icon from "./Icon.astro";
---

<footer class="border-t border-border px-5 py-12">
  <div class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-6 sm:flex-row sm:items-center">
    <div>
      <p class="font-semibold">{profile.name}</p>
      <p class="mt-1 text-sm text-muted">
        {profile.tagline} &middot; {profile.location}
      </p>
    </div>

    <nav aria-label="Contact" class="flex flex-wrap gap-3">
      <a
        href={profile.socials.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-11 items-center gap-2 rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium text-fg transition-colors duration-200 hover:bg-sand focus-visible:outline-none"
      >
        <Icon name="github" size={18} />
        GitHub
      </a>
      <a
        href={`mailto:${profile.email}`}
        class="inline-flex min-h-11 items-center gap-2 rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium text-fg transition-colors duration-200 hover:bg-sand focus-visible:outline-none"
      >
        <Icon name="mail" size={18} />
        {profile.email}
      </a>
    </nav>
  </div>
</footer>
