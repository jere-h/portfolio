---
import type { ProjectConfig } from "../config";
import { demoUrl, repoUrl, thumbUrl } from "../config";
import type { RepoMeta } from "../lib/github";
import { relativeDate } from "../lib/format";
import LanguageDot from "./LanguageDot.astro";
import Icon from "./Icon.astro";

interface Props {
  project: ProjectConfig;
  meta: RepoMeta | undefined;
  featured?: boolean;
  delay?: 0 | 1 | 2 | 3;
}

const { project, meta, featured = false, delay = 0 } = Astro.props;
const { title, description, repo } = project;

const language = meta?.language ?? null;
const topics = meta?.topics ?? [];
const updated = relativeDate(meta?.updatedAt ?? null);
const hasMeta = Boolean(language) || Boolean(updated) || topics.length > 0;

const live = demoUrl(repo);
const source = repoUrl(repo);
const thumb = thumbUrl(project, import.meta.env.BASE_URL);
---

<article
  data-reveal
  data-reveal-delay={delay || undefined}
  class:list={[
    "group flex h-full flex-col overflow-hidden rounded-lg border border-border bg-surface shadow-sm",
    "transition duration-300 ease-[cubic-bezier(.32,.72,0,1)]",
    "hover:-translate-y-0.5 hover:shadow-md hover:border-accent/40",
  ]}
>
  <!-- Live app screenshot. Warm gradient sits behind as a graceful fallback. -->
  <div
    class="relative aspect-[3/2] overflow-hidden border-b border-border"
    style="background: linear-gradient(135deg, #ffd9a8, #f7849b 45%, #a93a8f);"
  >
    <img
      src={thumb}
      alt={`Screenshot of the ${title} app`}
      width="1200"
      height="800"
      loading="lazy"
      decoding="async"
      class="absolute inset-0 h-full w-full object-cover object-top transition-transform duration-500 ease-[cubic-bezier(.32,.72,0,1)] group-hover:scale-[1.03]"
    />
  </div>

  <div class="flex flex-1 flex-col p-5 sm:p-6">
    <h3
      class:list={[
        "font-semibold tracking-[-0.02em]",
        featured ? "text-xl sm:text-2xl" : "text-lg",
      ]}
    >
      {title}
    </h3>

    <p
      class:list={[
        "mt-2 text-muted",
        featured ? "text-base" : "text-[0.95rem]",
      ]}
    >
      {description}
    </p>

    {
      hasMeta && (
        <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
          <LanguageDot language={language} />
          {topics.length > 0 && (
            <ul class="flex flex-wrap gap-2" aria-label="Topics">
              {topics.slice(0, 4).map((t) => (
                <li class="rounded-pill border border-border bg-sand px-2.5 py-0.5 font-mono text-xs text-muted">
                  {t}
                </li>
              ))}
            </ul>
          )}
          {updated && (
            <span class="tabular ml-auto text-xs text-muted">{updated}</span>
          )}
        </div>
      )
    }

    <div class="mt-auto flex flex-wrap gap-3 pt-6">
      <a
        href={live}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-11 items-center gap-1.5 rounded-md bg-accent px-4 py-2 text-sm font-medium text-on-accent shadow-sm transition-[transform,box-shadow] duration-200 hover:shadow-md active:translate-y-px focus-visible:outline-none"
        aria-label={`Open the live demo of ${title}`}
      >
        Live demo
        <Icon name="arrow-up-right" size={16} />
      </a>

      <a
        href={source}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-11 items-center gap-1.5 rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium text-fg transition-colors duration-200 hover:bg-sand focus-visible:outline-none"
        aria-label={`View ${title} on GitHub`}
      >
        <Icon name="github" size={16} />
        Code
      </a>
    </div>
  </div>
</article>
