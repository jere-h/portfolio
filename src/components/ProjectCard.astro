---
import type { ProjectConfig } from "../config";
import { demoUrl, repoUrl, thumbUrl } from "../config";
import type { RepoMeta } from "../lib/github";
import { relativeDate } from "../lib/format";
import LanguageDot from "./LanguageDot.astro";
import Icon from "./Icon.astro";

interface Props {
  project: ProjectConfig;
  meta: RepoMeta | undefined;
  featured?: boolean;
}

const { project, meta, featured = false } = Astro.props;
const { title, description, repo } = project;

const language = meta?.language ?? null;
const updated = relativeDate(meta?.updatedAt ?? null);
const hasMeta = Boolean(language) || Boolean(updated);

const live = demoUrl(repo);
const source = repoUrl(repo);
const thumb = thumbUrl(project, import.meta.env.BASE_URL);
---

<!-- One project as a portrait "trading card". The carousel (see the .deck-*
     styles in global.css) drives the coverflow transform on the wrapping
     slide; this article keeps the pointer-physics tilt + glow hooks. -->
<article
  data-tilt
  data-glow
  class:list={[
    "deck-card group relative flex h-full flex-col overflow-hidden rounded-lg border border-border bg-surface shadow-sm",
    "transition duration-300 ease-[cubic-bezier(.32,.72,0,1)]",
    "hover:shadow-lg hover:border-accent/40",
  ]}
>
  <!-- Live app screenshot. Warm gradient sits behind as a graceful fallback,
       with a diagonal sheen sweeping the face when the card is centered. -->
  <div
    class="relative aspect-[3/2] shrink-0 overflow-hidden border-b border-border"
    style="background: linear-gradient(135deg, var(--glow-0), var(--glow-1) 45%, var(--glow-3));"
  >
    <img
      src={thumb}
      alt={`Screenshot of the ${title} app`}
      width="1200"
      height="800"
      loading="lazy"
      decoding="async"
      class="absolute inset-0 h-full w-full object-cover object-top transition-transform duration-500 ease-[cubic-bezier(.32,.72,0,1)] group-hover:scale-[1.04]"
    />

    <span class="deck-sheen" aria-hidden="true"></span>

    {
      featured && (
        <span class="deck-badge">
          <Icon name="star" size={11} />
          Featured
        </span>
      )
    }
  </div>

  <div class="flex flex-1 flex-col p-5">
    <h3
      class="font-display text-xl font-semibold tracking-[-0.01em]"
      style="font-optical-sizing: auto;"
    >
      {title}
    </h3>

    <p class="deck-desc mt-2 text-[0.95rem] text-muted">{description}</p>

    {
      hasMeta && (
        <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
          <LanguageDot language={language} />
          {updated && (
            <span class="tabular ml-auto text-xs text-muted">{updated}</span>
          )}
        </div>
      )
    }

    <div class="mt-auto flex flex-wrap gap-3 pt-5">
      <a
        href={live}
        target="_blank"
        rel="noopener noreferrer"
        data-magnetic
        class="inline-flex min-h-11 items-center gap-1.5 rounded-md bg-accent px-4 py-2 text-sm font-medium text-on-accent shadow-sm transition-[transform,box-shadow] duration-200 hover:shadow-md active:translate-y-px"
        aria-label={`View the ${title} page`}
      >
        View page
        <Icon name="arrow-up-right" size={16} />
      </a>

      <a
        href={source}
        target="_blank"
        rel="noopener noreferrer"
        data-magnetic
        class="inline-flex min-h-11 items-center gap-1.5 rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium text-fg transition-colors duration-200 hover:bg-sand"
        aria-label={`View ${title} on GitHub`}
      >
        <Icon name="github" size={16} />
        Code
      </a>
    </div>
  </div>
</article>
