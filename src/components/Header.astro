---
import { profile } from "../config";
import ThemeToggle from "./ThemeToggle.astro";
---

<header
  class="sticky top-0 z-40 border-b border-border/70 bg-bg/85 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-3">
    <a
      href={import.meta.env.BASE_URL}
      class="font-mono text-sm font-medium tracking-tight text-fg hover:text-accent"
    >
      {profile.name}
    </a>
    <ThemeToggle />
  </div>
</header>
