---
import Icon from "./Icon.astro";
---

<button
  id="theme-toggle"
  type="button"
  aria-pressed="false"
  aria-label="Switch to dark theme"
  data-magnetic
  class="grid h-11 w-11 place-items-center rounded-pill border border-border bg-surface text-fg shadow-sm transition-colors duration-200 hover:bg-sand focus-visible:outline-none"
>
  <span class="toggle-icon icon-moon"><Icon name="moon" size={18} /></span>
  <span class="toggle-icon icon-sun"><Icon name="sun" size={18} /></span>
</button>

<style>
  /* Both icons share the same grid cell and crossfade with a quarter-turn
   * morph on theme change. Reduced motion keeps the swap instant. */
  .toggle-icon {
    grid-area: 1 / 1;
    display: inline-flex;
    transition:
      opacity 260ms ease,
      transform 460ms var(--ease-tactile);
  }

  .icon-sun {
    opacity: 0;
    transform: rotate(90deg) scale(0.4);
  }

  :global(:root.dark) .icon-sun {
    opacity: 1;
    transform: none;
  }

  :global(:root.dark) .icon-moon {
    opacity: 0;
    transform: rotate(-90deg) scale(0.4);
  }

  @media (prefers-reduced-motion: reduce) {
    .toggle-icon {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById("theme-toggle");
    if (!btn) return;

    function sync() {
      var isDark = document.documentElement.classList.contains("dark");
      btn.setAttribute("aria-pressed", String(isDark));
      btn.setAttribute(
        "aria-label",
        isDark ? "Switch to light theme" : "Switch to dark theme",
      );
    }

    function swapTheme() {
      var isDark = document.documentElement.classList.toggle("dark");
      try {
        localStorage.setItem("theme", isDark ? "dark" : "light");
      } catch (e) {}
      sync();
    }

    sync();

    btn.addEventListener("click", function () {
      var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // Fallback for unsupported browsers / reduced motion: today's
      // instant swap.
      if (!document.startViewTransition || reduce) {
        swapTheme();
        return;
      }

      // Light wipe: the new theme floods out from the toggle as an
      // expanding circle over the old snapshot.
      var r = btn.getBoundingClientRect();
      var x = r.left + r.width / 2;
      var y = r.top + r.height / 2;
      var endRadius = Math.hypot(
        Math.max(x, window.innerWidth - x),
        Math.max(y, window.innerHeight - y),
      );

      var transition = document.startViewTransition(swapTheme);
      transition.ready
        .then(function () {
          document.documentElement.animate(
            {
              clipPath: [
                "circle(0px at " + x + "px " + y + "px)",
                "circle(" + endRadius + "px at " + x + "px " + y + "px)",
              ],
            },
            {
              duration: 560,
              easing: "cubic-bezier(0.32, 0.72, 0, 1)",
              pseudoElement: "::view-transition-new(root)",
            },
          );
        })
        .catch(function () {});
    });
  })();
</script>
