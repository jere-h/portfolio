---
import Icon from "./Icon.astro";
---

<button
  id="theme-toggle"
  type="button"
  aria-pressed="false"
  aria-label="Switch to dark theme"
  class="inline-flex h-11 w-11 items-center justify-center rounded-pill border border-border bg-surface text-fg shadow-sm transition-colors duration-200 hover:bg-sand focus-visible:outline-none"
>
  <span class="icon-when-light inline-flex"><Icon name="moon" size={18} /></span>
  <span class="icon-when-dark hidden"><Icon name="sun" size={18} /></span>
</button>

<style>
  :global(:root.dark) .icon-when-light {
    display: none;
  }
  :global(:root.dark) .icon-when-dark {
    display: inline-flex;
  }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById("theme-toggle");
    if (!btn) return;
    function sync() {
      var isDark = document.documentElement.classList.contains("dark");
      btn.setAttribute("aria-pressed", String(isDark));
      btn.setAttribute(
        "aria-label",
        isDark ? "Switch to light theme" : "Switch to dark theme",
      );
    }
    sync();
    btn.addEventListener("click", function () {
      var isDark = document.documentElement.classList.toggle("dark");
      try {
        localStorage.setItem("theme", isDark ? "dark" : "light");
      } catch (e) {}
      sync();
    });
  })();
</script>
