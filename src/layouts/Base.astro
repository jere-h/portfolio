---
import "../styles/global.css";
import frauncesUrl from "../assets/fraunces-latin-var.woff2?url";
import { profile } from "../config";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${profile.name}, ${profile.tagline}`,
  description = profile.bio,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;

// BASE_URL may or may not carry a trailing slash depending on config; normalize
// so asset hrefs never end up with a double slash.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <meta name="color-scheme" content="light dark" />
    <link
      rel="preload"
      href={frauncesUrl}
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={profile.avatarUrl} />
    <meta name="twitter:card" content="summary" />

    <!--
      Theme is decided before first paint to avoid a flash: mark the document
      as JS-enabled (unlocks the entrance reveal), then apply the stored or
      system-preferred theme.
    -->
    <script is:inline>
      (function () {
        var root = document.documentElement;
        root.classList.add("js");
        try {
          var stored = localStorage.getItem("theme");
          var dark = stored
            ? stored === "dark"
            : window.matchMedia("(prefers-color-scheme: dark)").matches;
          root.classList.toggle("dark", dark);
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-dvh">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:border focus:border-border focus:bg-surface focus:px-4 focus:py-2 focus:text-fg focus:shadow-md"
    >
      Skip to content
    </a>

    <slot />

    <!--
      Entrance reveal. Content is visible without JS; when JS + motion are on,
      elements fade/translate in as they enter the viewport. Reduced-motion and
      no-IntersectionObserver visitors are revealed immediately.
    -->
    <script is:inline>
      (function () {
        var els = document.querySelectorAll("[data-reveal]");
        if (!els.length) return;
        var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduce || !("IntersectionObserver" in window)) {
          els.forEach(function (el) {
            el.classList.add("is-visible");
          });
          return;
        }
        // Where CSS scroll-driven animations are supported the reveal is
        // a reversible scrub handled entirely in global.css - skip the
        // one-shot observer so the two never fight.
        if (
          window.CSS &&
          CSS.supports &&
          CSS.supports("animation-timeline", "view()")
        ) {
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
        );
        els.forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>

    <!--
      Pointer physics (glow borders, card tilt, magnetic buttons). Only
      fetched on fine-pointer devices with motion allowed - touch and
      reduced-motion visitors never pay for the module.
    -->
    <script>
      const motionOK = window.matchMedia(
        "(prefers-reduced-motion: no-preference)",
      ).matches;
      if (motionOK && window.matchMedia("(pointer: fine)").matches) {
        import("../scripts/pointer").then((m) => m.initPointer());
      }
      // Touch counterpart: scroll position drives the card glow instead
      // of the cursor.
      if (motionOK && window.matchMedia("(pointer: coarse)").matches) {
        import("../scripts/scroll-spotlight").then((m) =>
          m.initScrollSpotlight(),
        );
      }
    </script>
  </body>
</html>
