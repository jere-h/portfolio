---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Icon from "../components/Icon.astro";
import { projects } from "../config";
import { getRepoMeta } from "../lib/github";

// Build-time fetch (fresh where reachable, cached fallback otherwise).
const meta = await getRepoMeta();

// One deck, featured first, then the rest - in their config order. Adding a
// project is now just one more card in the row, not more page to scroll.
const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
const deck = [...featured, ...rest];
---

<Base>
  <Header />

  <main id="main">
    <Hero />

    {
      deck.length > 0 && (
        <section
          class="mx-auto max-w-6xl px-5 py-12 sm:py-16"
          aria-labelledby="work-heading"
          data-carousel
        >
          <div
            class="mb-2 flex flex-wrap items-end justify-between gap-x-6 gap-y-3 px-1"
            data-reveal
          >
            <div>
              <h2 id="work-heading" class="eyebrow">
                Projects
              </h2>
              <p class="mt-2 max-w-md text-[0.95rem] text-muted">
                A deck of things I've built. Swipe, drag, or use the arrows to
                flip through - featured picks lead.
              </p>
            </div>

            <div class="fifa-controls flex items-center gap-2">
              <button
                type="button"
                data-carousel-prev
                class="fifa-nav-btn"
                aria-label="Previous project"
              >
                <Icon name="chevron-left" size={20} />
              </button>
              <button
                type="button"
                data-carousel-next
                class="fifa-nav-btn"
                aria-label="Next project"
              >
                <Icon name="chevron-right" size={20} />
              </button>
            </div>
          </div>

          <div class="fifa-carousel" data-reveal data-reveal-delay="1">
            <ul
              class="fifa-track"
              data-carousel-track
              aria-label="Projects carousel"
              aria-roledescription="carousel"
            >
              {deck.map((project, i) => (
                <li
                  class="fifa-slide"
                  data-slide
                  aria-label={`Project ${i + 1} of ${deck.length}: ${project.title}`}
                  aria-roledescription="slide"
                >
                  <div class="fifa-slide-inner" data-slide-inner>
                    <ProjectCard
                      project={project}
                      meta={meta[project.repo]}
                      featured={project.featured}
                    />
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <div
            class="fifa-controls mt-5 flex items-center justify-center gap-2"
            aria-hidden="true"
          >
            {deck.map((project, i) => (
              <button
                type="button"
                class="fifa-dot"
                data-dot
                tabindex="-1"
                aria-label={`Show ${project.title}`}
              />
            ))}
          </div>
        </section>
      )
    }
  </main>

  <Footer />
</Base>

<script>
  import { initCarousel } from "../scripts/carousel";
  initCarousel();
</script>
