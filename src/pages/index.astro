---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import Icon from "../components/Icon.astro";
import { projects } from "../config";
import { getRepoMeta } from "../lib/github";

// Build-time fetch (fresh where reachable, cached fallback otherwise).
const meta = await getRepoMeta();

// One deck, featured first, then the rest - in their config order. Adding a
// project is now just one more card in the row, not more page to scroll.
const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
const deck = [...featured, ...rest];
---

<Base>
  <!-- Floating theme toggle: keeps light/dark switching after the persistent
       header was removed, without repeating the name in a top bar. -->
  <div class="fixed right-4 top-4 z-[90]">
    <ThemeToggle />
  </div>

  <main id="main">
    <Hero />

    {
      deck.length > 0 && (
        <section
          class="overflow-x-clip pb-16 pt-4 sm:pb-20 sm:pt-6"
          aria-labelledby="work-heading"
          data-carousel
        >
          <h2
            id="work-heading"
            class="eyebrow mx-auto max-w-5xl px-5"
            data-reveal
          >
            Projects
          </h2>

          <div class="deck-carousel" data-reveal data-reveal-delay="1">
            <button
              type="button"
              data-carousel-prev
              class="deck-nav-btn deck-nav-prev"
              aria-label="Previous project"
            >
              <Icon name="chevron-left" size={20} />
            </button>
            <button
              type="button"
              data-carousel-next
              class="deck-nav-btn deck-nav-next"
              aria-label="Next project"
            >
              <Icon name="chevron-right" size={20} />
            </button>

            <ul
              class="deck-track"
              data-carousel-track
              aria-label="Projects carousel"
              aria-roledescription="carousel"
            >
              {deck.map((project, i) => (
                <li
                  class="deck-slide"
                  data-slide
                  aria-label={`Project ${i + 1} of ${deck.length}: ${project.title}`}
                  aria-roledescription="slide"
                >
                  <div class="deck-slide-inner" data-slide-inner>
                    <ProjectCard
                      project={project}
                      meta={meta[project.repo]}
                      featured={project.featured}
                    />
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <div
            class="deck-controls mt-5 flex items-center justify-center gap-2"
            aria-hidden="true"
          >
            {deck.map((project, i) => (
              <button
                type="button"
                class="deck-dot"
                data-dot
                tabindex="-1"
                aria-label={`Show ${project.title}`}
              />
            ))}
          </div>
        </section>
      )
    }
  </main>
</Base>

<script>
  import { initCarousel } from "../scripts/carousel";
  initCarousel();
</script>
